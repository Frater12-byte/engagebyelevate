# ============================================
# Engage by Elevate - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://engagebyelevate.com

# Security
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS
MAGIC_LINK_EXPIRY_HOURS=720  # 30 days (valid for event duration)

# Event dates (Day 1, 2 = UAE hotels; Day 3 = International)
EVENT_DAY_1=2026-06-01
EVENT_DAY_2=2026-06-02
EVENT_DAY_3=2026-06-03

# Meeting config
MEETING_DURATION_MINUTES=20
SLOT_LOCK_HOURS=48

# SMTP (for magic links and meeting notifications)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@engagebyelevate.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Engage by Elevate <noreply@engagebyelevate.com>"

# Microsoft Graph API (for Teams links)
# Register an app at https://entra.microsoft.com -> App Registrations
# Grant Application permissions: OnlineMeetings.ReadWrite.All, Calendars.ReadWrite
MS_TENANT_ID=your_tenant_id
MS_CLIENT_ID=your_client_id
MS_CLIENT_SECRET=your_client_secret
MS_ORGANIZER_USER_ID=organizer@yourdomain.com

# N8N webhook (optional - for external automation)
N8N_WEBHOOK_URL=https://n8n.yourserver.com/webhook/engage
N8N_WEBHOOK_SECRET=shared_secret_between_app_and_n8n

# Admin
ADMIN_EMAIL=admin@engagebyelevate.com
